# NextAuth Configuration
# ============================================================================
# CRITICAL: NEXTAUTH_SECRET is REQUIRED for production deployments
# This variable is validated at build time and the build will fail if it's missing
# ============================================================================
# Generate a secret using: openssl rand -base64 32
# This secret is used to sign and encrypt JWT tokens and must be set in production
# For local development, you can use any non-empty string, but a secure random value is recommended
NEXTAUTH_SECRET=your_secret_key_here

# NextAuth URL (used for OAuth callbacks)
# This variable is OPTIONAL and will be automatically determined based on the environment:
# - Production: Set this to your production domain (e.g., https://yourdomain.com)
# - Preview/Staging: If not set, will use VERCEL_URL environment variable (Vercel deployments)
# - Local Development: If not set, defaults to http://localhost:3000
# 
# For local development, you can leave this unset or set it to:
# NEXTAUTH_URL=http://localhost:3000
#
# For production, set it to your domain:
# NEXTAUTH_URL=https://yourdomain.com
#
# For Vercel preview deployments, leave this unset and the system will automatically
# use the VERCEL_URL environment variable provided by Vercel.
NEXTAUTH_URL=http://localhost:3000

# Yahoo OAuth Callback URL
# ============================================================================
# IMPORTANT: DO NOT SET THIS VARIABLE MANUALLY.
# 
# YAHOO_CALLBACK_URL is automatically generated at runtime by lib/get-callback-url.ts.
# It is derived from NEXTAUTH_URL (or VERCEL_URL) by appending /api/auth/callback/yahoo.
#
# The callback URL is dynamically computed based on your environment:
#   - Local Dev:    NEXTAUTH_URL=http://localhost:3000   => http://localhost:3000/api/auth/callback/yahoo
#   - Production:   NEXTAUTH_URL=https://yourdomain.com  => https://yourdomain.com/api/auth/callback/yahoo
#   - Vercel:       VERCEL_URL=my-app.vercel.app         => https://my-app.vercel.app/api/auth/callback/yahoo
#
# To register your callback URL in Yahoo's Developer Console:
# 1. Go to https://developer.yahoo.com/apps
# 2. Select your application
# 3. In "Redirect URIs", add the appropriate callback URL for your environment
# 4. For local development: http://localhost:3000/api/auth/callback/yahoo
# 5. For production: https://yourdomain.com/api/auth/callback/yahoo
#
# See docs/YAHOO_OAUTH_SETUP.md for detailed setup instructions.
# ============================================================================

# Yahoo OAuth Provider
# Create an OAuth app at: https://developer.yahoo.com/apps
# For local development, set Redirect URIs to: http://localhost:3000/api/auth/callback/yahoo
# For production, set Redirect URIs to: https://yourdomain.com/api/auth/callback/yahoo
YAHOO_AUTH_URL=https://api.login.yahoo.com/oauth2/request_auth
YAHOO_TOKEN_URL=https://api.login.yahoo.com/oauth2/get_token
YAHOO_CLIENT_ID=your_yahoo_client_id
YAHOO_CLIENT_SECRET=your_yahoo_client_secret
